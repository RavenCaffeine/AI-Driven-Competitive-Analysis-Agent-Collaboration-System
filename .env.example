# ==============================================
# Competitive Analysis Agent - Configuration
# ==============================================

# --- LLM Provider (default: deepseek) ---
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-deepseek-api-key-here
# LLM_BASE_URL=https://api.deepseek.com  # Optional: custom base URL
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# --- Alternative Providers (uncomment to switch) ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=your-openai-api-key

# LLM_PROVIDER=claude
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=your-anthropic-api-key

# --- Search Tools ---
TAVILY_API_KEY=your-tavily-api-key-here
# SERPER_API_KEY=your-serper-api-key
# JINA_API_KEY=your-jina-api-key

# --- Workflow ---
MAX_ITERATIONS=5
MAX_QA_RETRIES=2
AUTO_APPROVE=true
OUTPUT_DIR=./outputs

# --- Memory ---
MEMORY_ENABLED=true
MEMORY_STORAGE_PATH=
MEMORY_MAX_FACTS=100

# --- Logging ---
LOG_LEVEL=INFO
